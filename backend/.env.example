# Shield AI backend — copy to .env and fill in.
ENVIRONMENT=development
DEBUG=true
SHIELD_PROCESS=api

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME

DATABASE_URL=postgresql+psycopg://shield:REPLACE_WITH_LOCAL_PASSWORD@db:5432/shield_ai
REDIS_URL=redis://:REPLACE_WITH_LOCAL_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:REPLACE_WITH_LOCAL_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REPLACE_WITH_LOCAL_PASSWORD@redis:6379/2

# AI layer
ANTHROPIC_API_KEY=

# Threat intelligence APIs (Phase 1)
GOOGLE_SAFE_BROWSING_KEY=
VIRUSTOTAL_API_KEY=

# Limits
MAX_UPLOAD_MB=10
